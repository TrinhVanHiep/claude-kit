{
  "name": "@hieptv/claude-kit",
  "version": "0.1.8",
  "type": "module",
  "description": "A senior fullstack engineering team for Claude Code: 12 specialist agents, 5 workflow commands (pipeline/design-spec/debug/review-pr/refactor), design-to-spec from mockups, lazy-loaded domain rules, and real-time ESLint hooks — scaffolded into your repo with one command.",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "llm",
    "eslint",
    "hooks",
    "scaffolding",
    "multi-agent",
    "subagents",
    "pipeline",
    "code-review",
    "design-to-code",
    "figma",
    "mockup",
    "playwright",
    "developer-tools",
    "devtools",
    "code-quality",
    "automation"
  ],
  "homepage": "https://github.com/TrinhVanHiep/claude-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TrinhVanHiep/claude-kit.git"
  },
  "bugs": {
    "url": "https://github.com/TrinhVanHiep/claude-kit/issues"
  },
  "bin": {
    "aitop-claude": "bin/init.mjs"
  },
  "files": [
    "hooks",
    "bin",
    "templates",
    "scripts"
  ],
  "exports": {
    "./hooks/lint-edited-file": "./hooks/lint-edited-file.mjs",
    "./hooks/gate-stop": "./hooks/gate-stop.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "validate": "node scripts/validate-skills.mjs templates/agents templates/commands",
    "prepublishOnly": "npm run validate"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT"
}
